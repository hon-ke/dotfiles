{
    "layer": "top",
    "position": "top",
    "reload_style_on_change": true,
    "modules-left": [
        "clock"
    ],
    "modules-center": [
        "hyprland/workspaces",
    ],
    "modules-right": [
        "group/expand",
        "cpu",
        "memory",
        "tray",
        "backlight",
        "pulseaudio",
        "battery"
    ],
    "group/expand": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 600,
            "transition-to-left": true,
            "click-to-reveal": true
        },
        "modules": [
            "custom/expand",
            "custom/ip"
        ]
    },
    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "active": "ΎΕΣ",
            "default": "ΎΕΣ",
            "empty": "ΎΕΣ"
        },
        "persistent-workspaces": {
            "*": [
                1,
                2,
                3,
                4,
                5,
		6,
		7,
            ]
        }
    },
    "tray": {
        "icon-size": 18,
        "spacing": 10
    },
    "clock": {
        "format": "{:%a %b %e | %I:%M %p}",
        "interval": 1,
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
            "format": {
                "today": "<span color='#F56C6C'><b>{}</b></span>"
            }
        },
        "actions": {
            "on-click-right": "shift_down",
            "on-click": "shift_up"
        }
    },
    "battery": {
        "interval": 1,
        "format": "{icon}",
        "format-alt": "{icon} {capacity}%",
        "format-icons": {
            "charging": [
                "≤░λθ",
                "≤▒Λν",
                "≤▒Λξ",
                "≤▒Λο"
            ],
            "default": [
                "≤░Β║",
                "≤░Β╗",
                "≤░Β╝",
                "≤░Β╜",
                "≤░Β╛",
                "≤░Β┐",
                "≤░ΓΑ",
                "≤░ΓΒ",
                "≤░ΓΓ",
                "≤░Β╣"
            ]
        },
        "format-full": "≤░ΓΕ",
        "states": {
            "warning": 20,
            "critical": 10
        },
        "tooltip": "acpi",
    },
    "pulseaudio": {
        "format": "{icon}",
        "format-alt": "{icon} {volume}%",
        "format-bluetooth": "≤░Γ░",
        "nospacing": 1,
        "tooltip-format": "Volume : {volume}%",
        "format-muted": "≤░ζθ",
        "format-icons": {
            "headphone": "ΎΑξ",
            "default": [
		"≤░ζθ",
		"≤░Χ┐",
                "≤░ΨΑ",
                "≤░Χ╛",
            ]
        },
        "on-click": "",
        "scroll-step": 1
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon}",
        "format-alt": "{icon} {percent}%",
        "format-icons": [
            "≤▒σΟ",
            "≤▒σΠ",
            "≤▒σΡ",
            "≤▒σΣ",
            "≤▒σΤ",
            "≤▒σΦ",
            "≤▒σΧ",
            "≤▒σΧ",
            "≤▒σΨ",
        ]
    },
    "custom/expand": {
        "format": "ΎΕΕ",
        "tooltip": false
    },
    "custom/endpoint": {
        "format": "|",
        "tooltip": false
    },
    "cpu": {
        "interval": 1,
        "format": "{icon0}{icon1}{icon2}{icon3}{icon4}{icon5}{icon6}{icon7}",
        "format-icons": [
            "<span color='#69ff94'>έΨΒ</span>", // green
            "<span color='#69ff94'>έΨΓ</span>", // green
            "<span color='#69ff94'>έΨΔ</span>", // green
            "<span color='#2aa9ff'>έΨΕ</span>", // blue
            "<span color='#2aa9ff'>έΨΖ</span>", // blue
            "<span color='#ffffa5'>έΨΗ</span>", // yellow
            "<span color='#ff9977'>έΨΘ</span>", // orange
            "<span color='#dd532e'>έΨΙ</span>" // red
        ]
    },
    "memory": {
        "interval": 30,
        "format": "ΎΔΚ {used:0.1f}G/{total:0.1f}G"
    },
    "pulseaudio/slider": {
        "min": 0,
        "max": 100,
        "orientation": "horizontal"
    },
    "custom/ip": {
        "format": "Ό╣σ",
        "tooltip": false,
        "on-click": "~/.config/hypr/scripts/ip.sh &"
    }

}
